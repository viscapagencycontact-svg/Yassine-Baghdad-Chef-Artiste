<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Yassine Baghdad — Chef</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Montserrat:wght@100;200;300;400&display=swap" rel="stylesheet">
<style>
:root{--black:#050505;--white:#fff;--off:#fafafa;--gold:#b8973a;--gold2:#d4b86a}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Montserrat',sans-serif;background:var(--black);color:var(--white);overflow-x:hidden;-webkit-font-smoothing:antialiased;cursor:none}
img{display:block}

/* CURSOR */
#cur{position:fixed;pointer-events:none;z-index:9999;top:0;left:0}
.cd{width:4px;height:4px;background:var(--gold);border-radius:50%;position:absolute;transform:translate(-50%,-50%)}
.cr{width:28px;height:28px;border:1px solid rgba(184,151,58,.4);border-radius:50%;position:absolute;transform:translate(-50%,-50%);transition:all .18s ease}
body.h .cr{width:44px;height:44px;border-color:rgba(184,151,58,.85)}

/* PROGRESS */
#pb{position:fixed;top:0;left:0;right:0;height:1px;z-index:1000}
#pbs{display:block;height:100%;width:0;background:var(--gold);transition:width .08s}

/* NAV — plus visible avec fond semi-transparent dès le départ */
header{
  position:fixed;top:0;left:0;right:0;z-index:500;height:66px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 4rem;
  background:rgba(5,5,5,.65);
  backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(184,151,58,.15);
  transition:all .4s;
}
header.dk{
  background:rgba(5,5,5,.95);
  border-bottom:1px solid rgba(184,151,58,.2);
}
.logo{font-family:'Cormorant Garamond',serif;font-size:1rem;letter-spacing:.35em;text-transform:uppercase;font-weight:300;color:#fff}
.logo b{color:var(--gold);font-weight:300}
nav{display:flex;gap:2.5rem}
nav a{font-size:.57rem;letter-spacing:.2em;text-transform:uppercase;font-weight:300;color:rgba(255,255,255,.65);text-decoration:none;transition:color .3s;position:relative}
nav a::after{content:'';position:absolute;bottom:-2px;left:0;right:0;height:1px;background:var(--gold);transform:scaleX(0);transform-origin:right;transition:transform .4s cubic-bezier(.76,0,.24,1)}
nav a:hover{color:var(--gold)}
nav a:hover::after{transform:scaleX(1);transform-origin:left}
.bur{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px}
.bur span{display:block;width:22px;height:1px;background:#fff;transition:all .3s}
.mnav{position:fixed;inset:0;z-index:490;background:var(--black);display:none;flex-direction:column;align-items:center;justify-content:center;gap:3rem}
.mnav.op{display:flex}
.mnav a{font-family:'Cormorant Garamond',serif;font-size:2.4rem;font-style:italic;font-weight:300;color:#fff;text-decoration:none;transition:color .3s}
.mnav a:hover{color:var(--gold)}

/* HERO — photo plein écran, pas de vidéo */
#hero{height:100vh;position:relative;overflow:hidden;background:var(--black);display:flex;align-items:flex-end}
.hero-img{position:absolute;inset:0;z-index:0}
.hero-img img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block;transform:scale(1.04);animation:hzoom 2s cubic-bezier(.25,.46,.45,.94) forwards}
@keyframes hzoom{to{transform:scale(1)}}
.hero-img::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,rgba(5,5,5,.1) 0%,rgba(5,5,5,0) 30%,rgba(5,5,5,.92) 100%)}
.hero-content{position:relative;z-index:2;padding:0 6rem 7rem;width:100%}
.hl{width:0;height:1px;background:var(--gold);margin-bottom:2rem;animation:lg .9s .2s ease forwards}
@keyframes lg{to{width:60px}}
.ht{font-size:.56rem;letter-spacing:.38em;text-transform:uppercase;font-weight:200;color:var(--gold);margin-bottom:1.5rem;opacity:0;animation:fu .8s .3s forwards}
h1.hero-name{font-family:'Cormorant Garamond',serif;font-size:clamp(4.5rem,9vw,10rem);font-weight:300;line-height:.88;color:#fff;opacity:0;animation:fu .9s .45s forwards}
h1.hero-name em{display:block;font-style:italic;color:rgba(255,255,255,.8)}
.hs{margin-top:2rem;font-size:.67rem;letter-spacing:.2em;text-transform:uppercase;font-weight:200;color:rgba(255,255,255,.35);opacity:0;animation:fu .8s .7s forwards}
.hs span{color:var(--gold2)}
.hsc{position:absolute;right:4rem;bottom:7rem;z-index:2;display:flex;flex-direction:column;align-items:center;gap:.9rem;opacity:0;animation:fi 1s 1.5s forwards}
.hsl{width:1px;height:60px;background:linear-gradient(to bottom,transparent,var(--gold));animation:sp 2.2s 2s ease-in-out infinite}
@keyframes sp{0%,100%{transform:scaleY(.5);opacity:.3}50%{transform:scaleY(1);opacity:1}}
.hsc span{font-size:.48rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.25);writing-mode:vertical-rl}

/* VISION */
#vision{background:var(--black);padding:12rem 0;text-align:center}
.vi{max-width:760px;margin:0 auto;padding:0 2rem}
.stag{font-size:.53rem;letter-spacing:.32em;text-transform:uppercase;color:var(--gold);font-weight:300;margin-bottom:2.5rem;display:flex;align-items:center;justify-content:center;gap:1.5rem}
.stag::before,.stag::after{content:'';width:26px;height:1px;background:var(--gold)}
.vq{font-family:'Cormorant Garamond',serif;font-size:clamp(1.9rem,3.5vw,3.2rem);font-weight:300;line-height:1.55;color:#fff;font-style:italic}
.vq em{color:var(--gold);font-style:normal}
.orn{display:flex;align-items:center;justify-content:center;gap:1.5rem;margin:2.5rem 0}
.orn::before,.orn::after{content:'';flex:1;max-width:50px;height:1px;background:var(--gold);opacity:.35}
.orn span{color:var(--gold);opacity:.5;font-size:.8rem}
.vb{font-size:.78rem;line-height:2.3;color:rgba(255,255,255,.55);max-width:600px;margin:0 auto}

/* CHEF */
#chef{display:grid;grid-template-columns:1fr 1fr;min-height:100vh}
.cp{position:relative;overflow:hidden;background:var(--black)}
.cp img{width:100%;height:100%;object-fit:cover;object-position:top center;transition:transform 1.4s cubic-bezier(.25,.46,.45,.94);display:block}
.cp:hover img{transform:scale(1.03)}
.ct{display:flex;flex-direction:column;justify-content:center;padding:5rem 5rem 5rem 5.5rem;background:#fff;color:#000}
.ct .stag{justify-content:flex-start;margin-bottom:0}
.ct .stag::before{display:none}
.ct .stag::after{background:var(--gold)}
.ch2{font-family:'Cormorant Garamond',serif;font-size:clamp(2.2rem,3.5vw,3.8rem);font-weight:300;line-height:1.08;margin:1.5rem 0}
.ch2 em{font-style:italic;color:var(--gold)}
.cp2{font-size:.76rem;line-height:2.3;color:rgba(0,0,0,.45);margin-bottom:1rem}
.gr{width:40px;height:1px;background:var(--gold);margin:1.8rem 0}
.aw{display:flex;flex-direction:column;gap:0}
.ar{display:flex;align-items:flex-start;gap:1.2rem;padding:.7rem 0;border-bottom:1px solid rgba(157,127,62,.1)}
.ar:last-child{border-bottom:none}
.ad{width:5px;height:5px;border-radius:50%;background:var(--gold);flex-shrink:0;margin-top:4px}
.ar-text{font-size:.62rem;letter-spacing:.06em;text-transform:uppercase;color:rgba(0,0,0,.55);line-height:1.5}
.ar-text strong{color:rgba(0,0,0,.8);font-weight:500}

/* GALERIE EN SCÈNE — nouvelles photos Bocuse 2025 */
#galerie{background:var(--black);padding:2px 0 0}
.gal-head{max-width:1300px;margin:0 auto;padding:7rem 5rem 4rem;display:flex;align-items:flex-end;justify-content:space-between}
.gal-title{font-family:'Cormorant Garamond',serif;font-size:clamp(3rem,6vw,7rem);font-weight:300;color:#fff;line-height:1;letter-spacing:-.02em}
.gal-title em{font-style:italic;color:var(--gold2)}
.gal-desc{font-size:.72rem;line-height:2.1;color:rgba(255,255,255,.3);max-width:280px;padding-bottom:.5rem}
.gal-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;padding:0 2px 2px}
.gi{position:relative;overflow:hidden;background:#0e0d0b}
.gi img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 1.2s cubic-bezier(.25,.46,.45,.94),filter .5s;filter:brightness(.85)}
.gi:hover img{transform:scale(1.06);filter:brightness(.97)}
.gi-cap{position:absolute;bottom:0;left:0;right:0;padding:3.5rem 1.5rem 1.2rem;background:linear-gradient(transparent,rgba(5,5,5,.82));font-family:'Cormorant Garamond',serif;font-style:italic;font-size:.95rem;color:rgba(212,184,106,.95);opacity:0;transition:opacity .45s}
.gi:hover .gi-cap{opacity:1}
.gi.A{grid-column:1/3;aspect-ratio:16/10}
.gi.B{grid-column:3/4;aspect-ratio:4/5}
.gi.C{grid-column:4/5;aspect-ratio:4/5}
.gi.D{grid-column:1/2;aspect-ratio:4/5}
.gi.E{grid-column:2/4;aspect-ratio:16/10}
.gi.F{grid-column:4/5;aspect-ratio:4/5}

/* PLATS — nouvelle grille avec photos Bocuse officiel */
#plats{background:var(--black);padding:2px 0}
.plats-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;padding:0 2px 2px}
.pg{position:relative;overflow:hidden;background:#0e0d0b;aspect-ratio:4/3}
.pg img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 1s ease,filter .5s;filter:brightness(.9)}
.pg:hover img{transform:scale(1.04);filter:brightness(1)}
.pg-cap{position:absolute;bottom:0;left:0;right:0;padding:4rem 2rem 1.5rem;background:linear-gradient(transparent,rgba(5,5,5,.78));font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1rem;color:rgba(212,184,106,.9);opacity:0;transition:opacity .4s}
.pg:hover .pg-cap{opacity:1}

/* DISTINCTIONS */
#di{background:var(--black);padding:11rem 0}
.din{max-width:1200px;margin:0 auto;padding:0 5rem}
.dg{display:grid;grid-template-columns:1fr 1fr;gap:9rem;align-items:center;margin-top:5rem}
.dm{position:relative;overflow:hidden}
.dm img{width:100%;height:auto;display:block;transition:transform 1s ease}
.dm:hover img{transform:scale(1.03)}
.dm::before{content:'';position:absolute;top:-10px;left:-10px;width:80px;height:80px;border-top:1px solid var(--gold);border-left:1px solid var(--gold);z-index:1;pointer-events:none}
.dm::after{content:'';position:absolute;bottom:-10px;right:-10px;width:80px;height:80px;border-bottom:1px solid var(--gold);border-right:1px solid var(--gold);z-index:1;pointer-events:none}
.dl{display:flex;flex-direction:column}
.dit{display:grid;grid-template-columns:3rem 1fr;gap:2rem;align-items:start;padding:2.2rem 0;border-bottom:1px solid rgba(255,255,255,.06);transition:border-color .3s}
.dit:hover{border-bottom-color:rgba(184,151,58,.25)}
.dn{font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:300;color:rgba(184,151,58,.12);line-height:1}
.di2 h4{font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:400;margin-bottom:.5rem;color:#fff}
.di2 p{font-size:.7rem;line-height:1.95;color:rgba(255,255,255,.42);font-weight:200}

/* FLORAL */
#fl{background:var(--black);padding:10rem 0 0;overflow:hidden}
.flh{max-width:1200px;margin:0 auto;padding:0 5rem 6rem;display:grid;grid-template-columns:1fr 1fr;gap:8rem;align-items:end}
.flh-title{font-family:'Cormorant Garamond',serif;font-size:clamp(3rem,6vw,6.5rem);font-weight:300;line-height:.9;color:#fff;letter-spacing:-.02em}
.flh-title em{display:block;font-style:italic;color:var(--gold)}
.lbl{font-size:.52rem;letter-spacing:.5em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem;display:block}
.flh-aside p{font-size:.76rem;line-height:2.3;color:rgba(255,255,255,.45)}
.flh-aside strong{color:#fff;font-weight:400}
.marq-wrap{overflow:hidden;position:relative}
.marq-wrap::before,.marq-wrap::after{content:'';position:absolute;top:0;bottom:0;width:80px;z-index:2;pointer-events:none}
.marq-wrap::before{left:0;background:linear-gradient(to right,var(--black),transparent)}
.marq-wrap::after{right:0;background:linear-gradient(to left,var(--black),transparent)}
.marq-track{display:flex;gap:3px;width:max-content}
.marq-track.fwd{animation:mf 28s linear infinite}
.marq-track.bwd{animation:mb 34s linear infinite;margin-top:3px}
.marq-wrap:hover .marq-track{animation-play-state:paused}
@keyframes mf{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
@keyframes mb{0%{transform:translateX(-50%)}100%{transform:translateX(0)}}
.kf{flex-shrink:0;height:240px;overflow:hidden;background:#0e0d0b}
.kf img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .8s}
.kf:hover img{transform:scale(1.06)}
.kf.wh{background:#f5f2eb}
.kf.wh img{object-fit:contain}

/* EXPÉRIENCE */
#sh{background:var(--black);padding:11rem 0}
.shin{max-width:1200px;margin:0 auto;padding:0 5rem}
.sps{display:grid;grid-template-columns:repeat(3,1fr);gap:0;margin-top:5.5rem}
.ss{position:relative;padding:3.5rem 2.5rem 3.5rem 0;border-top:1px solid rgba(255,255,255,.07);transition:border-color .4s}
.ss:hover{border-top-color:var(--gold)}
.sn{font-family:'Cormorant Garamond',serif;font-size:6rem;font-weight:300;color:rgba(184,151,58,.07);line-height:1;margin-bottom:2rem}
.ss h4{font-family:'Cormorant Garamond',serif;font-size:1.45rem;font-weight:300;color:#fff;margin-bottom:1rem}
.ss p{font-size:.72rem;line-height:2;color:rgba(255,255,255,.38)}

/* ACCORDÉON */
.accordion{max-width:1200px;margin:5rem auto 0;padding:0 5rem}
.acc-item{border-bottom:1px solid rgba(255,255,255,.08)}
.acc-trigger{width:100%;background:none;border:none;display:flex;align-items:center;justify-content:space-between;padding:2rem 0;cursor:pointer;text-align:left}
.acc-title{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:300;color:rgba(255,255,255,.85);transition:color .3s}
.acc-title span{font-size:.55rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);font-weight:300;display:block;margin-bottom:.4rem;font-style:normal;font-family:'Montserrat',sans-serif}
.acc-trigger:hover .acc-title{color:var(--gold)}
.acc-icon{width:36px;height:36px;border:1px solid rgba(184,151,58,.3);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .35s;color:var(--gold);font-size:1.1rem}
.acc-item.open .acc-icon{transform:rotate(45deg);background:rgba(184,151,58,.1);border-color:var(--gold)}
.acc-body{display:none;padding:0 0 3rem}
.acc-item.open .acc-body{display:block;animation:fadeDown .4s ease forwards}
@keyframes fadeDown{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:none}}
.acc-intro{font-size:.78rem;line-height:2;color:rgba(255,255,255,.5);margin-bottom:2rem;font-style:italic;border-left:2px solid var(--gold);padding-left:1.2rem}
.acc-select-note{font-size:.62rem;letter-spacing:.15em;text-transform:uppercase;color:var(--gold2);margin-bottom:1.5rem;display:inline-flex;align-items:center;gap:.8rem;font-weight:300}
.acc-select-note::before{content:'✦';font-size:.5rem;opacity:.7}
.bouchees-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.5rem 3rem}
.bouchee-item{display:flex;align-items:flex-start;gap:1rem;padding:.6rem 0;border-bottom:1px solid rgba(255,255,255,.05);font-family:'Cormorant Garamond',serif;font-size:.98rem;font-style:italic;color:rgba(255,255,255,.65);transition:color .3s}
.bouchee-item::before{content:'·';color:var(--gold);font-size:1.2rem;line-height:1.2;flex-shrink:0}
.bouchee-item:hover{color:rgba(255,255,255,.9)}
.charc-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:1.5rem;margin-top:.5rem}
.charc-card{background:rgba(255,255,255,.03);border:1px solid rgba(184,151,58,.12);padding:1.8rem;transition:border-color .3s,background .3s}
.charc-card:hover{border-color:rgba(184,151,58,.4);background:rgba(184,151,58,.05)}
.charc-name{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:400;color:var(--white);margin-bottom:.4rem}
.charc-affi{font-size:.55rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:1.2rem;display:block}
.charc-mariages-title{font-size:.52rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-bottom:.8rem}
.charc-item{display:flex;align-items:flex-start;gap:.7rem;font-size:.72rem;line-height:1.7;color:rgba(255,255,255,.45);padding:.3rem 0;font-weight:200}
.charc-item::before{content:'—';color:rgba(184,151,58,.4);font-size:.7rem;flex-shrink:0;margin-top:1px}

/* SHOW PHOTOS */
.sf{display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px;margin-top:6rem}
.sfm{position:relative;overflow:hidden;background:#0e0d0b}
.sfm img{width:100%;height:100%;object-fit:cover;object-position:top center;display:block;transition:transform 1.3s cubic-bezier(.25,.46,.45,.94);filter:brightness(.85)}
.sfm:hover img{transform:scale(1.04);filter:brightness(.97)}
.sfm.main{grid-column:1/3;min-height:620px}
.sfm.side{min-height:310px}
.sfo{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:3rem 2.5rem;background:linear-gradient(transparent 50%,rgba(5,5,5,.85) 100%)}
.sft{font-size:.48rem;letter-spacing:.42em;text-transform:uppercase;color:var(--gold2);margin-bottom:.6rem}
.sfn{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;font-style:italic;color:#fff;line-height:1}

/* MENUS avec fleurs déco */
#me{background:var(--off);padding:11rem 0;position:relative;overflow:hidden}
.me-fleur{position:absolute;pointer-events:none;z-index:0}
.me-fleur img{width:100%;height:auto;display:block}
.me-fleur.tl{top:-3%;left:-6%;width:28%;opacity:.09;filter:blur(2.5px) saturate(.6);transform:rotate(-12deg)}
.me-fleur.br{bottom:-3%;right:-7%;width:26%;opacity:.08;filter:blur(2px) saturate(.6);transform:rotate(8deg)}
.me-fleur.tr{top:12%;right:-5%;width:20%;opacity:.07;filter:blur(3px) saturate(.5);transform:rotate(18deg)}
.mein{max-width:1200px;margin:0 auto;padding:0 5rem;position:relative;z-index:1}
.mein h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,4vw,4.5rem);font-weight:300;color:#000;line-height:1.08}
.mein h2 em{font-style:italic;color:var(--gold)}
.mein .stag{justify-content:flex-start;color:var(--gold)}
.mein .stag::before{display:none}
.mein .stag::after{background:var(--gold)}
.mtbs{display:flex;border-bottom:1px solid rgba(0,0,0,.07);margin:3.5rem 0 4.5rem;overflow-x:auto;-ms-overflow-style:none;scrollbar-width:none}
.mtbs::-webkit-scrollbar{display:none}
.mt{padding:1rem 2.2rem;font-size:.57rem;letter-spacing:.22em;text-transform:uppercase;font-weight:300;color:rgba(0,0,0,.28);background:none;border:none;cursor:pointer;border-bottom:2px solid transparent;transition:all .3s;white-space:nowrap}
.mt.on{color:#000;border-bottom-color:var(--gold)}
.mp{display:none}
.mp.on{display:block;animation:fadeIn .4s ease}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.prop-header{text-align:center;padding:0 0 3rem;border-bottom:1px solid rgba(168,135,58,.15);margin-bottom:3.5rem}
.prop-num{font-family:'Cormorant Garamond',serif;font-size:5rem;font-weight:300;font-style:italic;color:rgba(168,135,58,.12);line-height:1;margin-bottom:.5rem}
.prop-name{font-family:'Cormorant Garamond',serif;font-size:clamp(1.8rem,3vw,2.8rem);font-weight:300;color:#000}
.prop-name em{font-style:italic;color:var(--gold)}
.prop-courses{display:grid;grid-template-columns:repeat(3,1fr);gap:0}
.prop-course{padding:0 3rem;border-right:1px solid rgba(168,135,58,.12)}
.prop-course:first-child{padding-left:0}
.prop-course:last-child{border-right:none;padding-right:0}
.pc-label{font-size:.52rem;letter-spacing:.38em;text-transform:uppercase;color:var(--gold);font-weight:300;margin-bottom:1.2rem;padding-bottom:.8rem;border-bottom:1px solid rgba(168,135,58,.12);display:flex;align-items:center;gap:.8rem}
.pc-label::before{content:'';width:14px;height:1px;background:var(--gold);opacity:.5;flex-shrink:0}
.pc-dish{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:400;color:#000;margin-bottom:.6rem;line-height:1.25}
.pc-desc{font-family:'Cormorant Garamond',serif;font-size:.92rem;font-style:italic;color:rgba(0,0,0,.48);line-height:1.65}

/* CONTACT */
#co{position:relative;min-height:90vh;display:flex;align-items:center;justify-content:center;text-align:center;overflow:hidden}
.cobg{position:absolute;inset:0}
.cobg img{width:100%;height:100%;object-fit:cover;filter:brightness(.12) saturate(.5) sepia(.2);display:block}
.cobg::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(5,5,5,0),rgba(5,5,5,.6))}
.coc{position:relative;z-index:2;max-width:600px;padding:4rem 2rem}
.coc .stag{justify-content:center}
.cot{font-family:'Cormorant Garamond',serif;font-size:clamp(3rem,7vw,6.5rem);font-weight:300;line-height:.95;color:#fff;margin:2.2rem 0}
.cot em{font-style:italic;color:var(--gold);display:block}
.cop{font-size:.75rem;line-height:2.3;color:rgba(255,255,255,.38);max-width:440px;margin:0 auto 4rem}
.cos{font-family:'Cormorant Garamond',serif;font-size:2.4rem;font-style:italic;font-weight:300;color:var(--gold);margin-bottom:2rem}
.col-line{width:1px;height:50px;background:linear-gradient(to bottom,var(--gold),transparent);margin:0 auto 2rem}
.coh{font-size:.53rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.22)}

/* ANIMATIONS */
@keyframes fu{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}
@keyframes fi{from{opacity:0}to{opacity:1}}
.rv{opacity:0;transform:translateY(28px);transition:opacity 1.1s ease,transform 1.1s ease}
.rv.on{opacity:1;transform:none}
.rvl{opacity:0;transform:translateX(-28px);transition:opacity 1.1s ease,transform 1.1s ease}
.rvl.on{opacity:1;transform:none}
.rvr{opacity:0;transform:translateX(28px);transition:opacity 1.1s ease,transform 1.1s ease}
.rvr.on{opacity:1;transform:none}
.d1{transition-delay:.12s}.d2{transition-delay:.24s}.d3{transition-delay:.36s}

/* RESPONSIVE */
@media(max-width:1024px){
  .gal-grid{grid-template-columns:1fr 1fr}.gi{grid-column:auto!important;aspect-ratio:4/3}
  .plats-grid{grid-template-columns:1fr}
  .prop-courses{grid-template-columns:1fr;gap:2.5rem}
  .prop-course{border-right:none;padding:0;border-bottom:1px solid rgba(168,135,58,.1);padding-bottom:2rem}
  .prop-course:last-child{border-bottom:none;padding-bottom:0}
  .bouchees-grid{grid-template-columns:1fr}
  .charc-grid{grid-template-columns:1fr}
}
@media(max-width:900px){
  body{cursor:auto}#cur{display:none}
  header{padding:0 1.5rem}nav{display:none}.bur{display:flex}
  #hero .hero-content{padding:0 2rem 5rem}h1.hero-name{font-size:3.8rem}.hsc{display:none}
  #vision{padding:7rem 0}
  #chef{grid-template-columns:1fr}.cp{height:75vw}.ct{padding:4rem 2rem}
  .gal-head{flex-direction:column;padding:5rem 2rem 3rem;gap:2rem}
  .gal-grid{grid-template-columns:1fr}.gi{grid-column:auto!important;aspect-ratio:16/9}
  .din{padding:0 2rem}.dg{grid-template-columns:1fr;gap:4rem}
  #fl{padding:6rem 0}.flh{grid-template-columns:1fr;gap:3rem;padding:0 2rem 4rem}
  .kf{height:160px}
  .shin{padding:0 2rem}.sps{grid-template-columns:1fr;gap:0}
  .accordion{padding:0 2rem}
  .sf{grid-template-columns:1fr}.sfm.main{grid-column:auto;min-height:70vw}.sfm.side{min-height:50vw}
  .mein{padding:0 2rem}
  #di,#fl,#sh,#me{padding:6rem 0}
}
</style>
</head>
<body>

<div id="cur"><div class="cd"></div><div class="cr"></div></div>
<div id="pb"><span id="pbs"></span></div>

<header id="hdr">
  <div class="logo">Yassine <b>Baghdad</b></div>
  <nav>
    <a href="#chef">Le Chef</a>
    <a href="#galerie">En Scène</a>
    <a href="#di">Distinctions</a>
    <a href="#fl">Floral</a>
    <a href="#sh">Expérience</a>
    <a href="#me">Menus</a>
    <a href="#co">Contact</a>
  </nav>
  <button class="bur" onclick="tg()"><span></span><span></span><span></span></button>
</header>
<div class="mnav" id="mn">
  <a href="#chef" onclick="cl()">Le Chef</a>
  <a href="#galerie" onclick="cl()">En Scène</a>
  <a href="#di" onclick="cl()">Distinctions</a>
  <a href="#fl" onclick="cl()">Floral</a>
  <a href="#sh" onclick="cl()">Expérience</a>
  <a href="#me" onclick="cl()">Menus</a>
  <a href="#co" onclick="cl()">Contact</a>
</div>

<!-- HERO — photo plein écran (plus de vidéo) -->
<section id="hero">
  <div class="hero-img">
    <img src="data:image/jpeg;base64," alt="Yassine Baghdad — Bocuse d'Or 2025" loading="eager">
  </div>
  <div class="hero-content">
    <div class="hl"></div>
    <p class="ht">Chef · Artiste · Bocuse d'Or Africa 2024</p>
    <h1 class="hero-name">Yassine<em>Baghdad</em></h1>
    <p class="hs">Haute Gastronomie · <span>Paris</span> · Team Morocco 2025</p>
  </div>
  <div class="hsc"><div class="hsl"></div><span>Scroll</span></div>
</section>

<!-- VISION -->
<section id="vision">
  <div class="vi">
    <div class="stag rv">Vision</div>
    <p class="vq rv d1">Une cuisine guidée par l'émotion,<br><em>Pour moi, chaque création doit raconter une histoire,</em><br>centrée sur le terroir, l'art, et la culture.</p>
    <div class="orn rv d2"><span>✦</span></div>
    <p class="vb rv d3">Le Chef Yassine Baghdad propose une expérience sensorielle unique, alliant précision technique, esthétique raffinée et respect absolu du produit.</p>
  </div>
</section>

<!-- CHEF -->
<section id="chef">
  <div class="cp rvl"><img src="data:image/jpeg;base64," alt="Chef Yassine Baghdad" loading="lazy"></div>
  <div class="ct rvr">
    <div class="stag">Le Chef</div>
    <h2 class="ch2">Artiste &amp;<em>Cuisinier</em></h2>
    <p class="cp2">Animé par une grande passion pour l'art contemporain, dès le plus jeune âge, Yassine Baghdad compose ses assiettes comme des œuvres vivantes. Couleurs, textures et volumes dialoguent pour créer une harmonie visuelle et gustative sans égale.</p>
    <p class="cp2">Peintre autant que cuisinier, il revendique une vision totale de la création — de l'esquisse à la finalisation dans l'assiette.</p>
    <div class="gr"></div>
    <div class="aw">
      <div class="ar"><div class="ad"></div><span class="ar-text"><strong>Membre Auditeur de l'Académie Culinaire de France</strong> — depuis 2022</span></div>
      <div class="ar"><div class="ad"></div><span class="ar-text"><strong>Bocuse d'Or Maroc 2023</strong> — Vainqueur</span></div>
      <div class="ar"><div class="ad"></div><span class="ar-text"><strong>Bocuse d'Or Africa 2024</strong> — Vainqueur</span></div>
      <div class="ar"><div class="ad"></div><span class="ar-text"><strong>La Liste 1000</strong> — Lauréat 2024</span></div>
      <div class="ar"><div class="ad"></div><span class="ar-text"><strong>Disciples d'Auguste Escoffier</strong></span></div>
      <div class="ar"><div class="ad"></div><span class="ar-text"><strong>Bocuse d'Or Monde</strong> · Finaliste 2025</span></div>
    </div>
  </div>
</section>

<!-- GALERIE EN SCÈNE — nouvelles photos Bocuse 2025 -->
<section id="galerie">
  <div class="gal-head">
    <h2 class="gal-title rv">En <em style="display:inline">Scène</em></h2>
    <p class="gal-desc rv d1">Bocuse d'Or Monde 2025, Lyon — le Chef en compétition, dans la précision du geste et l'intensité de la création.</p>
  </div>
  <div class="gal-grid rv">
    <div class="gi A"><img src="data:image/jpeg;base64," alt="" loading="lazy"><div class="gi-cap">La Découpe Précise</div></div>
    <div class="gi B"><img src="data:image/jpeg;base64," alt="" loading="lazy"><div class="gi-cap">Concentration</div></div>
    <div class="gi C"><img src="data:image/jpeg;base64," alt="" loading="lazy"><div class="gi-cap">La Langouste</div></div>
    <div class="gi D"><img src="data:image/jpeg;base64," alt="" loading="lazy"><div class="gi-cap">La Texture</div></div>
    <div class="gi E"><img src="data:image/jpeg;base64," alt="" loading="lazy"><div class="gi-cap">L'Équipe — Dressage Final</div></div>
    <div class="gi F"><img src="data:image/jpeg;base64," alt="" loading="lazy"><div class="gi-cap">Le Geste</div></div>
  </div>
</section>

<!-- PLATS OFFICIELS BOCUSE -->
<section id="plats">
  <div class="plats-grid">
    <div class="pg"><img src="data:image/jpeg;base64," alt="Plat officiel Morocco — Bocuse d'Or 2025" loading="lazy"><div class="pg-cap">Plat Officiel — Team Morocco · Bocuse d'Or 2025</div></div>
    <div class="pg"><img src="data:image/jpeg;base64," alt="Platter officiel Morocco — Bocuse d'Or 2025" loading="lazy"><div class="pg-cap">Platter Officiel — Team Morocco · Bocuse d'Or 2025</div></div>
    <div class="pg"><img src="data:image/jpeg;base64," alt="Bouchées cocktail" loading="lazy"><div class="pg-cap">Bouchées Cocktail — Présentation</div></div>
    <div class="pg"><img src="data:image/jpeg;base64," alt="Plateau Bocuse d'Or" loading="lazy"><div class="pg-cap">Plateau Signature — Bocuse d'Or</div></div>
  </div>
</section>

<!-- DISTINCTIONS -->
<section id="di">
  <div class="din">
    <div class="rv" style="text-align:center">
      <div class="stag" style="justify-content:center">Parcours</div>
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,4vw,4.5rem);font-weight:300;color:#fff">Excellence &amp; <em style="font-style:italic;color:var(--gold)">Distinctions</em></h2>
    </div>
    <div class="dg">
      <div class="dm rvl"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div>
      <div class="dl rvr">
        <div class="dit"><div class="dn">01</div><div class="di2"><h4>Bocuse d'Or Africa 2024</h4><p>Vainqueur de la sélection africaine — représentant la Team Morocco à la Finale Mondiale SIRHA 2025 à Lyon</p></div></div>
        <div class="dit"><div class="dn">02</div><div class="di2"><h4>La Liste 1000 — 2024</h4><p>Lauréat de la reconnaissance internationale d'excellence gastronomique</p></div></div>
        <div class="dit"><div class="dn">03</div><div class="di2"><h4>Disciples d'Auguste Escoffier</h4><p>Membre du cercle d'élite de la haute gastronomie mondiale</p></div></div>
        <div class="dit"><div class="dn">04</div><div class="di2"><h4>Marché International de Rungis, Île-de-France</h4><p>Approvisionnement direct — premier marché mondial de produits frais, sélection de produits de grande qualité pour les chefs étoilés</p></div></div>
      </div>
    </div>
  </div>
</section>

<!-- FLORAL -->
<section id="fl">
  <div class="flh">
    <div class="rvl"><h2 class="flh-title">L'élégance<em>florale</em></h2></div>
    <div class="flh-aside rvr">
      <span class="lbl">Koppert Cress</span>
      <p>L'élégance ne se décrète pas, elle se compose. Pour Yassine Baghdad, l'assiette est une toile en mouvement. Grâce à l'expertise de <strong>Koppert Cress</strong>, le végétal devient matière à expression, apportant relief, lumière et contraste.</p>
    </div>
  </div>
  <div class="marq-wrap rv">
    <div class="marq-track fwd"><div class="kf" style="width:390px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf" style="width:390px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf" style="width:390px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf" style="width:390px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf" style="width:390px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf" style="width:390px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf" style="width:390px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf" style="width:390px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf" style="width:390px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf" style="width:390px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf" style="width:390px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf" style="width:390px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div></div>
    <div class="marq-track bwd"><div class="kf wh" style="width:340px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf wh" style="width:340px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf wh" style="width:340px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf wh" style="width:340px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf wh" style="width:340px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf wh" style="width:340px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf wh" style="width:340px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf wh" style="width:340px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf wh" style="width:340px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div><div class="kf wh" style="width:340px"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div></div>
  </div>
</section>

<!-- EXPÉRIENCE + ACCORDÉON -->
<section id="sh">
  <div class="shin">
    <div class="rv" style="text-align:center">
      <div class="stag">L'expérience</div>
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,4vw,4.5rem);font-weight:300;color:#fff">Un véritable <em style="font-style:italic;color:var(--gold)">Show Culinaire</em></h2>
    </div>
    <div class="sps">
      <div class="ss rv d1">
        <div class="sn">01</div>
        <h4>Le Cocktail de Bienvenue</h4>
        <p>Le Chef Yassine Baghdad finalise en direct les dernières préparations, sous les yeux des convives dès leur arrivée.</p>
      </div>
      <div class="ss rv d2">
        <div class="sn">02</div>
        <h4>Le Dressage en Direct</h4>
        <p>Les entrées sont dressées face aux invités avec explications et présentation de chaque produit.</p>
      </div>
      <div class="ss rv d3">
        <div class="sn">03</div>
        <h4>Le Final Artistique</h4>
        <p>Création d'un tableau vivant en live à partir du dessert, auquel les convives participent avant de le déguster.</p>
      </div>
    </div>
  </div>

  <div class="accordion rv d1">
    <!-- COCKTAIL DE BIENVENUE — Bouchées + Charcuteries -->
    <div class="acc-item">
      <button class="acc-trigger" onclick="toggleAcc(this)">
        <div class="acc-title">
          <span>01 · Cocktail de Bienvenue</span>
          Bouchées Cocktail &amp; Sélection Charcuteries
        </div>
        <div class="acc-icon">+</div>
      </button>
      <div class="acc-body">
        <p class="acc-intro">Pour composer votre cocktail de bienvenue, choisissez <strong>4 bouchées cocktail</strong> et <strong>3 marques de charcuterie</strong> parmi les sélections ci-dessous.</p>

        <!-- BOUCHÉES -->
        <div class="acc-select-note">Choisissez 4 bouchées cocktail</div>
        <div class="bouchees-grid" style="margin-bottom:3rem">
          <div class="bouchee-item">Éclair au saumon fumé et écume légère</div>
          <div class="bouchee-item">Tartare de thon rouge, navets Hakurei et caviar Sétiéra</div>
          <div class="bouchee-item">Rosace d'ananas au crabe</div>
          <div class="bouchee-item">Foie gras mi-cuit, chutney de figues au poivre long, brioche toastée</div>
          <div class="bouchee-item">Tartare de wagyu A5, gelée légère au miso et perles de yuzu</div>
          <div class="bouchee-item">Chèvre flambé, pignons de pin et miel de lavande</div>
          <div class="bouchee-item">Mini croque au jambon de veau et fromage comté</div>
          <div class="bouchee-item">Tartelette d'asperges, crème épicée et gel de bergamote</div>
          <div class="bouchee-item">Bouchée de parmesan, trilogie de textures : sablé, panna cotta et poudre de cèpes</div>
          <div class="bouchee-item">Corne fraîche de granny smith à la livèche, crème fine aux agrumes</div>
        </div>

        <!-- LIGNE SÉPARATRICE -->
        <div style="width:100%;height:1px;background:rgba(184,151,58,.15);margin:1rem 0 2.5rem"></div>

        <!-- CHARCUTERIES -->
        <div class="acc-select-note">Choisissez 3 marques de charcuterie</div>
        <div class="charc-grid">
          <div class="charc-card">
            <div class="charc-name">Cecina</div>
            <span class="charc-affi">24 mois d'affinage</span>
            <div class="charc-mariages-title">Mariages de luxe</div>
            <div class="charc-item">Huile d'olive extra vierge premium</div>
            <div class="charc-item">Parmesan Reggiano 36 mois, copeaux très fins</div>
            <div class="charc-item">Brisures de truffe</div>
            <div class="charc-item">Fleur de sel fumée de Guérande vieillie</div>
          </div>
          <div class="charc-card">
            <div class="charc-name">Suprême de Black Angus</div>
            <span class="charc-affi">&nbsp;</span>
            <div class="charc-mariages-title">Mariages de luxe</div>
            <div class="charc-item">Beurre de baratte demi-sel affiné</div>
            <div class="charc-item">Moutarde ancienne artisanale</div>
            <div class="charc-item">Noisettes du Piémont torréfiées</div>
            <div class="charc-item">Pain au levain longuement fermenté</div>
          </div>
          <div class="charc-card">
            <div class="charc-name">Jambon d'agneau affiné</div>
            <span class="charc-affi">&nbsp;</span>
            <div class="charc-mariages-title">Mariages de luxe</div>
            <div class="charc-item">Miel de thym</div>
            <div class="charc-item">Fromage de brebis affiné</div>
            <div class="charc-item">Amandes Marcona toastées</div>
            <div class="charc-item">Huile d'olive fruitée mûre</div>
          </div>
          <div class="charc-card">
            <div class="charc-name">Jambon de veau</div>
            <span class="charc-affi">&nbsp;</span>
            <div class="charc-mariages-title">Mariages de luxe</div>
            <div class="charc-item">Crème crue légère</div>
            <div class="charc-item">Zestes de citron confit maison</div>
            <div class="charc-item">Caviar d'aubergine blanc</div>
            <div class="charc-item">Poivre blanc de Kampot</div>
          </div>
          <div class="charc-card">
            <div class="charc-name">Suprême de Wagyu</div>
            <span class="charc-affi">&nbsp;</span>
            <div class="charc-mariages-title">Mariages de luxe</div>
            <div class="charc-item">Fleur de sel de Maldon</div>
            <div class="charc-item">Wasabi frais râpé</div>
            <div class="charc-item">Radis roses pickles</div>
            <div class="charc-item">Sauce soja vieillie</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- PHOTOS SHOW — nouvelles Bocuse 2025 -->
  <div class="sf rv">
    <div class="sfm main">
      <img src="data:image/jpeg;base64," alt="Bocuse d'Or 2025 — Langouste" loading="lazy">
      <div class="sfo">
        <div class="sft">Bocuse d'Or Monde · Lyon 2025</div>
        <div class="sfn">Yassine Baghdad</div>
      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:2px">
      <div class="sfm side"><img src="data:image/jpeg;base64," alt="Découpe précise" loading="lazy"></div>
      <div class="sfm side">
        <img src="data:image/jpeg;base64," alt="Équipe dressage" loading="lazy">
        <div class="sfo" style="padding:1.5rem 1.8rem"><div class="sft">L'Équipe</div><div class="sfn" style="font-size:1.3rem">Le Dressage Final</div></div>
      </div>
    </div>
  </div>
</section>

<!-- MENUS -->
<section id="me">
  <div class="me-fleur tl"><img src="data:image/jpeg;base64," alt=""></div>
  <div class="me-fleur br"><img src="data:image/jpeg;base64," alt=""></div>
  <div class="me-fleur tr"><img src="data:image/jpeg;base64," alt=""></div>

  <div class="mein">
    <div class="rv">
      <div class="stag">Gastronomie</div>
      <h2>Propositions <em>Menus</em></h2>
    </div>
    <div class="mtbs rv d1">
      <button class="mt on" onclick="sw('p1',this)">Proposition 1</button>
      <button class="mt" onclick="sw('p2',this)">Proposition 2</button>
      <button class="mt" onclick="sw('p3',this)">Proposition 3</button>
    </div>

    <div class="mp on" id="mp-p1">
      <div class="prop-header"><div class="prop-num">I</div><div class="prop-name">Proposition <em>Un</em></div></div>
      <div class="prop-courses">
        <div class="prop-course"><div class="pc-label">Entrée</div><div class="pc-dish">Fraîcheur de langoustines aux accents exotiques</div><div class="pc-desc">Mangue, papaye verte, vinaigrette à la passion</div></div>
        <div class="prop-course"><div class="pc-label">Plat</div><div class="pc-dish">Loup de bar poêlé</div><div class="pc-desc">Rose de céleri-rave, note de chocolat, beurre noisette</div></div>
        <div class="prop-course"><div class="pc-label">Dessert</div><div class="pc-dish">Coco givré, fraîcheur et légèreté exotique</div><div class="pc-desc">&nbsp;</div></div>
      </div>
    </div>

    <div class="mp" id="mp-p2">
      <div class="prop-header"><div class="prop-num">II</div><div class="prop-name">Proposition <em>Deux</em></div></div>
      <div class="prop-courses">
        <div class="prop-course"><div class="pc-label">Entrée</div><div class="pc-dish">Fleur de Saint-Jacques, jus d'hibiscus</div><div class="pc-desc">Pétales de rose croustillants</div></div>
        <div class="prop-course"><div class="pc-label">Plat</div><div class="pc-dish">Langouste, déclinaison de carotte</div><div class="pc-desc">Carotte glacée, mousseline de carotte aux agrumes, poudre de carotte, bisque légère</div></div>
        <div class="prop-course"><div class="pc-label">Dessert</div><div class="pc-dish">Éclat de fruits rouges au jasmin</div><div class="pc-desc">Pointe de poivre de Sichuan</div></div>
      </div>
    </div>

    <div class="mp" id="mp-p3">
      <div class="prop-header"><div class="prop-num">III</div><div class="prop-name">Proposition <em>Trois</em></div></div>
      <div class="prop-courses">
        <div class="prop-course"><div class="pc-label">Entrée</div><div class="pc-dish">Œuf parfait, asperges blanches glacées à l'agave</div><div class="pc-desc">Jus d'ail noir, reflets dorés</div></div>
        <div class="prop-course"><div class="pc-label">Plat</div><div class="pc-dish">Wagyu grillé à la robata, lecture de betterave</div><div class="pc-desc">Jus réduit au miso, nuance de poivre fumé</div></div>
        <div class="prop-course"><div class="pc-label">Dessert</div><div class="pc-dish">Vacherin croustillant à la pêche blanche</div><div class="pc-desc">Touche de rose</div></div>
      </div>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section id="co">
  <div class="cobg"><img src="data:image/jpeg;base64," alt="" loading="lazy"></div>
  <div class="coc rv">
    <div class="stag">Contact</div>
    <h2 class="cot">Créons ensemble<em>l'exception</em></h2>
    <p class="cop">Le Chef et son équipe restent à votre entière disposition pour concevoir une expérience culinaire sur mesure, à la hauteur de vos attentes les plus exigeantes.</p>
    <div class="cos">Yassine Baghdad</div>
    <div class="col-line"></div>
    <div class="coh">@chefdyali &nbsp;·&nbsp; Instagram</div>
  </div>
</section>

<script>
const cur=document.getElementById('cur'),cd=cur.querySelector('.cd'),cr=cur.querySelector('.cr');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cd.style.left=mx+'px';cd.style.top=my+'px';});
(function t(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;cr.style.left=rx+'px';cr.style.top=ry+'px';requestAnimationFrame(t);})();
document.querySelectorAll('a,button,.gi,.kf,.sfm,.dm,.cp,.mt,.acc-trigger,.charc-card,.pg').forEach(el=>{
  el.addEventListener('mouseenter',()=>document.body.classList.add('h'));
  el.addEventListener('mouseleave',()=>document.body.classList.remove('h'));
});
const hdr=document.getElementById('hdr'),pbs=document.getElementById('pbs');
window.addEventListener('scroll',()=>{
  hdr.classList.toggle('dk',scrollY>60);
  pbs.style.width=(scrollY/(document.documentElement.scrollHeight-innerHeight)*100)+'%';
});
function tg(){document.getElementById('mn').classList.toggle('op');}
function cl(){document.getElementById('mn').classList.remove('op');}
const obs=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('on');});},{threshold:0.07,rootMargin:'0px 0px -60px 0px'});
document.querySelectorAll('.rv,.rvl,.rvr').forEach(el=>obs.observe(el));
function sw(id,btn){
  document.querySelectorAll('.mp').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.mt').forEach(t=>t.classList.remove('on'));
  document.getElementById('mp-'+id).classList.add('on');btn.classList.add('on');
}
function toggleAcc(btn){
  var item=btn.closest('.acc-item');
  var wasOpen=item.classList.contains('open');
  document.querySelectorAll('.acc-item').forEach(function(i){i.classList.remove('open');});
  if(!wasOpen){item.classList.add('open');}
}
</script>
</body>
</html>
